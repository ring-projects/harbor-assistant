enum UserStatus {
  active
  disabled
}

enum AuthProvider {
  github
}

model User {
  id           String         @id @default(cuid())
  githubLogin  String         @unique
  name         String?
  email        String?
  avatarUrl    String?
  status       UserStatus     @default(active)
  lastLoginAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  identities   AuthIdentity[]
  sessions     AuthSession[]
  issuedAgentTokens AgentToken[] @relation("IssuedAgentTokens")
  projects     Project[]
  workspacesCreated Workspace[] @relation("WorkspaceCreatedByUser")
  workspaceMemberships WorkspaceMembership[] @relation("WorkspaceMemberships")
  workspaceInvitationsSent WorkspaceInvitation[] @relation("WorkspaceInvitationsSent")
  workspaceInvitationsAccepted WorkspaceInvitation[] @relation("WorkspaceInvitationsAccepted")
  linkedWorkspaceGitHubInstallations WorkspaceGitHubInstallation[]
  githubAppInstallations GitHubAppInstallation[]

  @@index([status, updatedAt(sort: Desc)])
  @@map("users")
}

model AuthIdentity {
  id             String       @id @default(cuid())
  userId         String
  provider       AuthProvider
  providerUserId String
  providerLogin  String
  providerEmail  String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId, provider])
  @@map("auth_identities")
}

model AuthSession {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  lastSeenAt DateTime?
  revokedAt  DateTime?
  userAgent  String?
  ip         String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([expiresAt, revokedAt])
  @@map("auth_sessions")
}

model AgentToken {
  id                String       @id @default(cuid())
  name              String?
  tokenHash         String       @unique
  issuedByUserId    String?
  parentTokenId     String?
  projectId         String?
  orchestrationId   String?
  taskId            String?
  sourceTaskId      String?
  scopes            Json
  expiresAt         DateTime
  lastSeenAt        DateTime?
  revokedAt         DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  issuedByUser      User?        @relation("IssuedAgentTokens", fields: [issuedByUserId], references: [id], onDelete: SetNull)
  parentToken       AgentToken?  @relation("DelegatedAgentTokens", fields: [parentTokenId], references: [id], onDelete: SetNull)
  delegatedTokens   AgentToken[] @relation("DelegatedAgentTokens")

  @@index([issuedByUserId, createdAt(sort: Desc)])
  @@index([projectId, createdAt(sort: Desc)])
  @@index([orchestrationId, createdAt(sort: Desc)])
  @@index([taskId, createdAt(sort: Desc)])
  @@index([sourceTaskId, createdAt(sort: Desc)])
  @@index([expiresAt, revokedAt])
  @@map("agent_tokens")
}
