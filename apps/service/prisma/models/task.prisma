enum TaskStatus {
  queued
  running
  completed
  failed
  cancelled
}

enum TaskMessageRole {
  user
  assistant
  system
}

enum TaskTimelineItemKind {
  message
  status
  stdout
  stderr
  summary
  error
  system
}

model Task {
  id            String             @id @default(cuid())
  projectId     String
  projectPath   String
  prompt        String
  executor      String
  model         String?
  status        TaskStatus         @default(queued)
  threadId      String?
  parentTaskId  String?
  startedAt     DateTime?
  finishedAt    DateTime?
  exitCode      Int?
  command       String?
  stdout        String             @default("")
  stderr        String             @default("")
  error         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  parentTask    Task?              @relation("TaskLineage", fields: [parentTaskId], references: [id], onDelete: SetNull)
  childTasks    Task[]             @relation("TaskLineage")
  timelineItems TaskTimelineItem[]

  @@index([projectId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([threadId, status, createdAt(sort: Desc)])
  @@index([parentTaskId, createdAt(sort: Desc)])
  @@map("tasks")
}

model TaskTimelineItem {
  id         String               @id @default(cuid())
  taskId     String
  sequence   Int
  kind       TaskTimelineItemKind
  role       TaskMessageRole?
  status     TaskStatus?
  source     String?
  content    String?
  payload    String?
  createdAt  DateTime             @default(now())
  task       Task                 @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, sequence])
  @@index([taskId, createdAt(sort: Asc)])
  @@index([taskId, kind, sequence])
  @@map("task_timeline_items")
}
