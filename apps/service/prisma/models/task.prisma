enum TaskStatus {
  queued
  running
  completed
  failed
  cancelled
}

enum TaskTitleSource {
  prompt
  agent
  user
}

model Task {
  id          String          @id @default(cuid())
  projectId   String
  prompt      String
  title       String
  titleSource TaskTitleSource @default(prompt)
  status      TaskStatus      @default(queued)
  startedAt   DateTime?
  finishedAt  DateTime?
  archivedAt  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  execution   Execution?

  @@index([projectId, createdAt(sort: Desc)])
  @@index([projectId, archivedAt, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@map("tasks")
}
