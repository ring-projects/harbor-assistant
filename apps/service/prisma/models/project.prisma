enum ProjectStatus {
  active
  archived
  missing
}

model Project {
  id                   String        @id @default(uuid())
  name                 String
  slug                 String?       @unique
  rootPath             String
  normalizedPath       String        @unique
  description          String?
  status               ProjectStatus @default(active)
  lastOpenedAt         DateTime?
  logRetentionDays     Int?          @default(30)
  eventRetentionDays   Int?          @default(7)
  harborSkillsEnabled  Boolean       @default(false)
  harborSkillProfile   String?       @default("default")
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  archivedAt           DateTime?
  tasks                Task[]

  @@index([status, updatedAt(sort: Desc)])
  @@map("projects")
}
