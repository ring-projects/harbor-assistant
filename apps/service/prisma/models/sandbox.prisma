model Sandbox {
  id                String           @id
  provider          String
  providerSandboxId String           @unique
  mode              String
  status            String
  source            Json
  workingDirectory  String
  profile           Json
  networkPolicy     Json
  workspaceId       String?
  projectId         String?
  taskId            String?
  purpose           String
  labels            Json
  previewBaseUrl    String?
  failureReason     String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  lastReadyAt       DateTime?
  stoppedAt         DateTime?
  commands          SandboxCommand[]
  snapshots         SandboxSnapshot[]

  @@index([projectId, createdAt(sort: Desc)])
  @@index([taskId, createdAt(sort: Desc)])
  @@index([status, updatedAt(sort: Desc)])
  @@map("sandboxes")
}

model SandboxCommand {
  id                String   @id
  sandboxId         String
  providerCommandId String
  command           String
  cwd               String?
  detached          Boolean  @default(false)
  status            String
  exitCode          Int?
  errorMessage      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  startedAt         DateTime?
  finishedAt        DateTime?
  sandbox           Sandbox  @relation(fields: [sandboxId], references: [id], onDelete: Cascade)

  @@unique([sandboxId, providerCommandId])
  @@index([sandboxId, createdAt(sort: Desc)])
  @@index([status, updatedAt(sort: Desc)])
  @@map("sandbox_commands")
}

model SandboxSnapshot {
  id                 String   @id
  sandboxId          String
  providerSnapshotId String   @unique
  providerSnapshotRef String?
  createdAt          DateTime @default(now())
  sandbox            Sandbox  @relation(fields: [sandboxId], references: [id], onDelete: Cascade)

  @@index([sandboxId, createdAt(sort: Desc)])
  @@map("sandbox_snapshots")
}
