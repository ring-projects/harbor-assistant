{
  "name": "@harbor/service",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.5",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "bun src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "bun run typecheck",
    "typecheck": "bunx tsc --noEmit -p tsconfig.json",
    "db:generate": "bunx --bun prisma generate",
    "db:migrate:dev": "bunx --bun prisma migrate dev",
    "db:migrate:deploy": "bunx --bun prisma migrate deploy",
    "db:studio": "bunx --bun prisma studio"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@openai/codex-sdk": "^0.111.0",
    "@prisma/client": "6.19.2",
    "fastify": "^5.8.1",
    "fastify-plugin": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "dotenv": "^17.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "6.19.2",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
