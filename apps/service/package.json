{
  "name": "@harbor/service",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "pnpm run typecheck",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "db:generate": "node ../../scripts/run-service-prisma.mjs generate",
    "db:migrate:dev": "node ../../scripts/run-service-prisma.mjs migrate dev",
    "db:migrate:deploy": "node ../../scripts/run-service-prisma.mjs migrate deploy",
    "db:studio": "node ../../scripts/run-service-prisma.mjs studio"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@openai/codex-sdk": "^0.111.0",
    "@prisma/client": "6.19.2",
    "fastify": "^5.8.1",
    "fastify-plugin": "^5.1.0",
    "socket.io": "^4.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "@types/node": "^20",
    "dotenv": "^17.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "6.19.2",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
