{
  "name": "@harbor/service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "pnpm run typecheck",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "db:generate": "node ../../scripts/run-service-prisma.mjs generate",
    "db:push": "node ../../scripts/run-service-prisma.mjs db push --skip-generate",
    "db:studio": "node ../../scripts/run-service-prisma.mjs studio"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "@fastify/cors": "^11.2.0",
    "@openai/codex-sdk": "^0.111.0",
    "@prisma/client": "6.19.2",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.1",
    "fastify-plugin": "^5.1.0",
    "prisma": "6.19.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/ws": "^8.18.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
