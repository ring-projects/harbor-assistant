{
  "name": "harbor-assistant",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=24.11.1",
    "pnpm": ">=10.20.0"
  },
  "scripts": {
    "changeset": "pnpm dlx @changesets/cli",
    "init:harbor": "node scripts/init.mjs",
    "dev": "pnpm run dev:web",
    "dev:all": "pnpm run init:harbor && pnpm -r --filter '@harbor/*' dev",
    "dev:web": "pnpm run init:harbor && pnpm --dir apps/web dev",
    "test:web": "pnpm --dir apps/web test",
    "build:web": "pnpm --dir apps/web build",
    "start:web": "pnpm --dir apps/web start",
    "lint": "pnpm run lint:web && pnpm run lint:service",
    "lint:web": "pnpm --dir apps/web lint",
    "lint:service": "pnpm --dir apps/service lint",
    "typecheck": "pnpm run typecheck:web && pnpm run typecheck:service",
    "typecheck:web": "pnpm --dir apps/web typecheck",
    "typecheck:service": "pnpm --dir apps/service typecheck",
    "db:generate": "pnpm --dir apps/service db:generate",
    "db:migrate:dev": "pnpm --dir apps/service db:migrate:dev",
    "db:migrate:deploy": "pnpm --dir apps/service db:migrate:deploy",
    "db:studio": "pnpm --dir apps/service db:studio",
    "dev:service": "pnpm --dir apps/service dev",
    "start:service": "pnpm --dir apps/service start",
    "release:status": "pnpm dlx @changesets/cli status --verbose",
    "version:packages": "pnpm dlx @changesets/cli version && node scripts/sync-workspace-version.mjs",
    "format": "pnpm exec prettier --write .",
    "format:check": "pnpm exec prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "yaml": "^2.8.2"
  }
}
