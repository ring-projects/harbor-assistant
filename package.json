{
  "name": "harbor-assistant",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.5",
  "engines": {
    "bun": ">=1.3.5"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "init:harbor": "bun scripts/init.mjs",
    "dev": "bun run dev:web",
    "dev:all": "bun run init:harbor && bun run --filter '@harbor/*' dev",
    "dev:web": "bun run init:harbor && bun run --cwd apps/web dev",
    "test:web": "bun run --cwd apps/web test",
    "build:web": "bun run --cwd apps/web build",
    "start:web": "bun run --cwd apps/web start",
    "lint": "bun run lint:web && bun run lint:service",
    "lint:web": "bun run --cwd apps/web lint",
    "lint:service": "bun run --cwd apps/service lint",
    "typecheck": "bun run typecheck:web && bun run typecheck:service",
    "typecheck:web": "bun run --cwd apps/web typecheck",
    "typecheck:service": "bun run --cwd apps/service typecheck",
    "db:generate": "bun run --cwd apps/service db:generate",
    "db:migrate:dev": "bun run --cwd apps/service db:migrate:dev",
    "db:migrate:deploy": "bun run --cwd apps/service db:migrate:deploy",
    "db:studio": "bun run --cwd apps/service db:studio",
    "dev:service": "bun run --cwd apps/service dev",
    "start:service": "bun run --cwd apps/service start",
    "format": "bunx prettier --write .",
    "format:check": "bunx prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "@prisma/client",
    "@prisma/engines",
    "prisma",
    "sharp",
    "unrs-resolver"
  ]
}
